{
  "name": "@repo/e2e",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "seed": "bun --env-file=../../.env scripts/seed.ts",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:api": "playwright test --project=api",
    "test:api:lifecycle": "playwright test --project=api tests/api/lifecycle.spec.ts",
    "test:web": "playwright test --project=web",
    "test:web:smoke": "npm run seed && PLAYWRIGHT_REUSE_EXISTING_SERVER=1 PLAYWRIGHT_HTML_OPEN=never playwright test --project=web tests/web/smoke.spec.ts",
    "report": "playwright show-report",
    "codegen": "playwright codegen"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@types/node": "^20.11.0",
    "bun-types": "^1.3.9",
    "dotenv": "^16.4.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "playwright": "1.42.0",
    "@repo/database": "workspace:*"
  }
}
